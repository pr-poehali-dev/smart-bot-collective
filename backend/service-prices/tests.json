{
  "tests": [
    {
      "name": "Get all prices",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"categories": "array", "regions": "array", "prices": "array"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get prices by category",
      "method": "GET",
      "path": "/?category=otdelochnye",
