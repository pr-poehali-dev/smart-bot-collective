    },
    {
      "name": "Get prices with region",
      "method": "GET",
      "path": "/?region=moscow",
      "expectedStatus": 200,
      "expectedBody": {"selected_region": "string", "total_items": "number"},
      "bodyMatcher": "partial"
    }
  ]
}
