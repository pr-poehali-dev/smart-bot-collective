{
  "tests": [
    {
      "name": "Reject request without token",
      "method": "GET",
      "path": "/?action=stats",
      "expectedStatus": 401,
      "expectedBody": {
        "error": "Unauthorized"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Reject request without token for report",
      "method": "GET",
      "path": "/?action=report",
      "expectedStatus": 401,
      "expectedBody": {
        "error": "Unauthorized"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Handle OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    }
  ]
}